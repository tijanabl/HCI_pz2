<UserControl x:Class="NetworkService.Views.NetworkDisplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NetworkService.ViewModel"
             xmlns:model="clr-namespace:NetworkService.Model"
             xmlns:behaviors="clr-namespace:NetworkService.Helpers"
             Background="{StaticResource PrimaryBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="10,6"
                Background="{StaticResource SecondaryBackground}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock Text="Network Display"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentCyan}"
                           VerticalAlignment="Center"/>
                <Button Content="Auto"
                        HorizontalAlignment="Right"
                        Command="{Binding AutoArrangeCommand}"
                        ToolTip="Automatski rasporedi sve entitete"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="155"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TreeView Grid.Column="0" Margin="4"
                      ItemsSource="{Binding GroupedEntities}"
                      behaviors:DragDropBehavior.EnableDrag="True"
                      ToolTip="Prevucite entitet na mrežu">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="True"/>
                        <Setter Property="Foreground"
                                Value="{StaticResource TextPrimary}"/>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.Resources>
                    <HierarchicalDataTemplate
                        DataType="{x:Type model:EntityTypeGroup}"
                        ItemsSource="{Binding Entities}">
                        <TextBlock Text="{Binding TypeName}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentCyan}"/>
                    </HierarchicalDataTemplate>
                    <DataTemplate DataType="{x:Type model:EntityDisplayItem}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{Binding ImagePath}"
                                   Width="20" Height="20"
                                   Margin="0,2,5,2"/>
                            <TextBlock Text="{Binding Name}"
                                       VerticalAlignment="Center"
                                       FontSize="11"/>
                        </StackPanel>
                    </DataTemplate>
                </TreeView.Resources>
            </TreeView>

            <Grid Grid.Column="1">

                <UniformGrid x:Name="CanvasGrid"
                             Columns="3" Rows="4"
                             Margin="4"
                             behaviors:AutoArrangeBehavior.EnableAutoArrange="True">

                    <Canvas Margin="3" Background="#243447"
                            behaviors:CanvasDropBehavior.CanvasIndex="0">
                        <TextBlock Tag="number" Text="0"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#647882"
                                   Canvas.Left="38" Canvas.Top="35"/>
                        <TextBlock Tag="info" FontSize="9"
                                   TextWrapping="Wrap" Width="88"
                                   Canvas.Left="4" Canvas.Top="68"/>
                    </Canvas>

                    <Canvas Margin="3" Background="#243447"
                            behaviors:CanvasDropBehavior.CanvasIndex="1">
                        <TextBlock Tag="number" Text="1"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#647882"
                                   Canvas.Left="38" Canvas.Top="35"/>
                        <TextBlock Tag="info" FontSize="9"
                                   TextWrapping="Wrap" Width="88"
                                   Canvas.Left="4" Canvas.Top="68"/>
                    </Canvas>

                    <Canvas Margin="3" Background="#243447"
                            behaviors:CanvasDropBehavior.CanvasIndex="2">
                        <TextBlock Tag="number" Text="2"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#647882"
                                   Canvas.Left="38" Canvas.Top="35"/>
                        <TextBlock Tag="info" FontSize="9"
                                   TextWrapping="Wrap" Width="88"
                                   Canvas.Left="4" Canvas.Top="68"/>
                    </Canvas>

                    <Canvas Margin="3" Background="#243447"
                            behaviors:CanvasDropBehavior.CanvasIndex="3">
                        <TextBlock Tag="number" Text="3"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#647882"
                                   Canvas.Left="38" Canvas.Top="35"/>
                        <TextBlock Tag="info" FontSize="9"
                                   TextWrapping="Wrap" Width="88"
                                   Canvas.Left="4" Canvas.Top="68"/>
                    </Canvas>

                    <Canvas Margin="3" Background="#243447"
                            behaviors:CanvasDropBehavior.CanvasIndex="4">
                        <TextBlock Tag="number" Text="4"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#647882"
                                   Canvas.Left="38" Canvas.Top="35"/>
                        <TextBlock Tag="info" FontSize="9"
                                   TextWrapping="Wrap" Width="88"
                                   Canvas.Left="4" Canvas.Top="68"/>
                    </Canvas>

                    <Canvas Margin="3" Background="#243447"
                            behaviors:CanvasDropBehavior.CanvasIndex="5">
                        <TextBlock Tag="number" Text="5"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#647882"
                                   Canvas.Left="38" Canvas.Top="35"/>
                        <TextBlock Tag="info" FontSize="9"
                                   TextWrapping="Wrap" Width="88"
                                   Canvas.Left="4" Canvas.Top="68"/>
                    </Canvas>

                    <Canvas Margin="3" Background="#243447"
                            behaviors:CanvasDropBehavior.CanvasIndex="6">
                        <TextBlock Tag="number" Text="6"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#647882"
                                   Canvas.Left="38" Canvas.Top="35"/>
                        <TextBlock Tag="info" FontSize="9"
                                   TextWrapping="Wrap" Width="88"
                                   Canvas.Left="4" Canvas.Top="68"/>
                    </Canvas>

                    <Canvas Margin="3" Background="#243447"
                            behaviors:CanvasDropBehavior.CanvasIndex="7">
                        <TextBlock Tag="number" Text="7"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#647882"
                                   Canvas.Left="38" Canvas.Top="35"/>
                        <TextBlock Tag="info" FontSize="9"
                                   TextWrapping="Wrap" Width="88"
                                   Canvas.Left="4" Canvas.Top="68"/>
                    </Canvas>

                    <Canvas Margin="3" Background="#243447"
                            behaviors:CanvasDropBehavior.CanvasIndex="8">
                        <TextBlock Tag="number" Text="8"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#647882"
                                   Canvas.Left="38" Canvas.Top="35"/>
                        <TextBlock Tag="info" FontSize="9"
                                   TextWrapping="Wrap" Width="88"
                                   Canvas.Left="4" Canvas.Top="68"/>
                    </Canvas>

                    <Canvas Margin="3" Background="#243447"
                            behaviors:CanvasDropBehavior.CanvasIndex="9">
                        <TextBlock Tag="number" Text="9"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#647882"
                                   Canvas.Left="38" Canvas.Top="35"/>
                        <TextBlock Tag="info" FontSize="9"
                                   TextWrapping="Wrap" Width="88"
                                   Canvas.Left="4" Canvas.Top="68"/>
                    </Canvas>

                    <Canvas Margin="3" Background="#243447"
                            behaviors:CanvasDropBehavior.CanvasIndex="10">
                        <TextBlock Tag="number" Text="10"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#647882"
                                   Canvas.Left="32" Canvas.Top="35"/>
                        <TextBlock Tag="info" FontSize="9"
                                   TextWrapping="Wrap" Width="88"
                                   Canvas.Left="4" Canvas.Top="68"/>
                    </Canvas>

                    <Canvas Margin="3" Background="#243447"
                            behaviors:CanvasDropBehavior.CanvasIndex="11">
                        <TextBlock Tag="number" Text="11"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#647882"
                                   Canvas.Left="32" Canvas.Top="35"/>
                        <TextBlock Tag="info" FontSize="9"
                                   TextWrapping="Wrap" Width="88"
                                   Canvas.Left="4" Canvas.Top="68"/>
                    </Canvas>

                </UniformGrid>

                <Canvas x:Name="LinesCanvas"
                        IsHitTestVisible="False"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        behaviors:LineDrawingBehavior.EnableLines="True"/>

            </Grid>
        </Grid>
    </Grid>
</UserControl>