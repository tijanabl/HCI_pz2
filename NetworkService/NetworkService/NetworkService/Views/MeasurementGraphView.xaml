<UserControl x:Class="NetworkService.Views.MeasurementGraphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NetworkService.ViewModel"
             Background="{StaticResource PrimaryBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Measurement Graph"
                   FontSize="22" FontWeight="Bold"
                   Foreground="{StaticResource AccentCyan}"
                   Margin="15,10,0,5"/>

        <Border Grid.Row="1" Padding="10,8"
                Background="{StaticResource SecondaryBackground}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,1,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Entitet:" VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <ComboBox Width="220"
                          ItemsSource="{Binding AllEntities}"
                          SelectedItem="{Binding SelectedEntity, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <StackPanel Orientation="Horizontal" Margin="20,0,0,0"
                            VerticalAlignment="Center">
                    <Ellipse Width="12" Height="12"
                             Fill="{StaticResource ValidGreen}" Margin="0,0,5,0"/>
                    <TextBlock Text="Validna vrijednost"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="12" Margin="0,0,15,0"/>
                    <Ellipse Width="12" Height="12"
                             Fill="{StaticResource InvalidRed}" Margin="0,0,5,0"/>
                    <TextBlock Text="Nevalidna vrijednost"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Margin="10"
                Background="{StaticResource SecondaryBackground}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1" CornerRadius="6">
            <Grid>
                <TextBlock Text="Izaberite entitet i sacekajte mjerenja..."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="14">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedEntity}"
                                             Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>


                <ItemsControl ItemsSource="{Binding GraphPoints}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                            <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:GraphPoint}">
                            <Canvas Width="{Binding Diameter}" Height="{Binding Diameter}">
                                <Line Visibility="{Binding HasLine,Converter={StaticResource BoolToVisibilityConverter}}"
                                      X1="{Binding Radius}" Y1="{Binding Radius}"
                                      X2="{Binding LineX2}" Y2="{Binding LineY2}"
                                      Stroke="#647882" StrokeThickness="2"
                                      StrokeDashArray="4 2"/>
                                <Ellipse Width="{Binding Diameter}"
                                         Height="{Binding Diameter}"
                                         Fill="{Binding FillColor}"
                                         Stroke="White" StrokeThickness="1.5"/>
                                <TextBlock Text="{Binding ValueText}"
                                           Width="{Binding Diameter}"
                                           TextAlignment="Center"
                                           Foreground="White"
                                           FontSize="11" FontWeight="Bold"
                                           Canvas.Left="0"
                                           Canvas.Top="15"/>
                                <TextBlock Text="{Binding TimeText}"
                                           Width="65"
                                           TextAlignment="Center"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="9"
                                           Canvas.Left="-8"
                                           Canvas.Top="54"/>
                            </Canvas>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <Border Grid.Row="3" Padding="10,4"
                Background="{StaticResource SecondaryBackground}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="T4 - DER validni opseg: "
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="12"/>
                <TextBlock Text="1.00 - 5.00 MW"
                           Foreground="{StaticResource AccentCyan}"
                           FontWeight="SemiBold" FontSize="12"/>
                <TextBlock Text="  |  Prikazuje poslednih 5 mjerenja"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>